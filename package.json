{
  "name": "tree-ide",
  "version": "1.0.0",
  "description": "Tree IDE, a lightweight, open-source project structure editor",
  "author": "Mare",
  "license": "MIT",
  "homepage": "https://github.com/TreeIDE/TreeIDE/tree/main/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TreeIDE/TreeIDE.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.treeide.treeide",
    "productName": "Tree IDE",
    "win": {
      "target": [
        "msi"
      ],
      "icon": "assets/icon-no-bg.ico",
      "signAndEditExecutable": false
    }
  }
}
